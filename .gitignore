# macOS
.DS_Store

# Python
__pycache__/
*.py[cod]
.env
*.egg-info/
.venv/

# Node
node_modules/
dist/
.env.local

# Claude Code workspace files
.claude/

# Obsidian user workspace (personal settings — not the project vault)
# obsidian-vault/.obsidian/ is intentionally committed (project config)

# Firebase deployment cache
.firebase/

# Cloud Run env vars file (mirrors .env — keep off version control)
backend/env-vars.yaml

# GCP — service account / credential JSON files
# Covers: service-account*.json, *credentials*.json,
# and GCP Console download format: project-name-hexhash.json
*.json.key
service-account*.json
*credentials*.json
*-[0-9a-f][0-9a-f][0-9a-f][0-9a-f][0-9a-f][0-9a-f][0-9a-f][0-9a-f]*.json
